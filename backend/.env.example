# Node Environment
NODE_ENV=development

# Server Port
PORT=5000

# MongoDB Connection Strings
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/moneycircle?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# CORS Origin
CORS_ORIGIN=*

# Log Level
LOG_LEVEL=info

# Database Name
DATABASE_NAME=moneycircle